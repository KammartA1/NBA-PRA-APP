# ============================================================
# Supabase Configuration — Persistent Storage
# ============================================================
# 1. Create a free project at https://supabase.com
# 2. Run supabase_schema.sql in the SQL Editor
# 3. Copy your project URL and service_role key from Settings > API
# 4. Paste them below and rename this file to secrets.toml
#    OR add them in Streamlit Cloud: App Dashboard > Edit Secrets
#
# IMPORTANT: Use the service_role key (not anon key) — it bypasses
# Row Level Security which is safe since Streamlit runs server-side.
# ============================================================

SUPABASE_URL = "https://your-project-id.supabase.co"
SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here"
